{
    "name": "e2e-scripts",
    "version": "1.0.0",
    "description": "E2E test scripts for PWA Kit",
    "main": "index.js",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "pwa-kit-dev lint \"*.js\"",
        "lint:fix": "pwa-kit-dev lint \"*.js\" --fix"
    },
    "devDependencies": {
        "jest": "^26.6.3",
        "@aws-sdk/client-s3": "^3.450.0",
        "@aws-sdk/client-sts": "^3.450.0",
        "@salesforce/pwa-kit-dev": "^3.12.0-dev",
        "prettier": "^2.8.6",
        "eslint": "^8.59.0"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/*.test.js"
        ],
        "collectCoverageFrom": [
            "*.js",
            "!*.test.js"
        ],
        "coverageDirectory": "coverage"
    }
}
