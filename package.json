{
  "name": "pwa-kit",
  "version": "4.0.0-extensibility-preview.5",
  "scripts": {
    "bump-version": "node ./scripts/bump-version/index.js",
    "bump-version:chakra-storefront": "node ./scripts/bump-version/index.js --package=template-chakra-storefront",
    "bump-version:commerce-sdk-react": "node ./scripts/bump-version/index.js --package=@salesforce/commerce-sdk-react",
    "bump-version:template-chakra-storefront": "node ./scripts/bump-version/index.js --package=@salesforce/template-chakra-storefront",
    "bump-version:extension-chakra-store-locator": "node ./scripts/bump-version/index.js --package=@salesforce/extension-chakra-store-locator",
    "bump-version:extension-starter": "node ./scripts/bump-version/index.js --package=@salesforce/extension-starter",
    "publish-to-npm": "node ./scripts/publish-to-npm.js",
    "format": "lerna run --stream format",
    "preinstall": "node ./scripts/check-version.js",
    "postinstall": "node ./scripts/bootstrap.js && node ./scripts/check-lockfiles.mjs",
    "lerna": "lerna",
    "lint": "lerna run --stream lint",
    "lint:fix": "lerna run lint:fix",
    "start": "npm start --prefix packages/template-chakra-storefront",
    "pretest": "npm run lint",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test": "lerna run --stream --concurrency=1 test",
    "test:max-file-size": "lerna run --stream test:max-file-size",
    "check-dep-version": "syncpack list-mismatches"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "commander": "^9.5.0",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-no-relative-import-paths": "^1.5.3",
    "jsdom": "^22.1.0",
    "lerna": "^6.6.1",
    "semver": "^7.5.2",
    "shelljs": "^0.9.2",
    "syncpack": "^10.1.0"
  },
  "engines": {
    "node": "^16.11.0 || ^18.0.0 || ^20.0.0 || ^22.0.0",
    "npm": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0"
  },
  "dependencies": {
    "@babel/parser": "^7.27.5",
    "@babel/traverse": "^7.27.4",
    "node-fetch": "^2.6.9",
    "prettier": "^3.6.2"
  }
}
