{
  "template": "pagenotfound",
  "path": "*",
  "componentPath": "./pages/page-not-found",
  "structure": [
    {
      "type": "Box",
      "props": {
        "layerStyle": "page",
        "className": "page-not-found",
        "height": "100%",
        "padding": {
          "lg": 8,
          "md": 6,
          "sm": 0,
          "base": 0
        }
      },
      "children": [
        {
          "type": "Helmet",
          "children": [
            {
              "type": "title"
            }
          ]
        },
        {
          "type": "Flex",
          "props": {
            "h": "100%",
            "justify": "center",
            "align": "center",
            "flexDirection": "column",
            "px": {
              "base": 5,
              "md": 12
            },
            "py": {
              "base": 48,
              "md": 60
            }
          },
          "children": [
            {
              "type": "SearchIcon",
              "props": {
                "boxSize": [
                  "30px",
                  "32px"
                ],
                "mb": 8
              }
            },
            {
              "type": "Heading",
              "props": {
                "as": "h2",
                "fontSize": [
                  "xl",
                  "2xl",
                  "2xl",
                  "3xl"
                ],
                "mb": 2,
                "align": "center"
              }
            },
            {
              "type": "Box",
              "props": {
                "mb": 12
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "textAlign": "center"
                  }
                }
              ]
            },
            {
              "type": "Stack",
              "props": {
                "direction": [
                  "column",
                  "row"
                ],
                "width": [
                  "100%",
                  "auto"
                ]
              },
              "children": [
                {
                  "type": "Button",
                  "props": {
                    "variant": "outline",
                    "bg": "white",
                    "onClick": "<function>",
                    "borderColor": "gray.200"
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "as": {
                      "type": "identifier",
                      "name": "Link"
                    },
                    "to": "/"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}