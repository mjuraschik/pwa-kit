{
  "template": "registration",
  "path": "/registration",
  "componentPath": "./pages/registration",
  "structure": [
    {
      "type": "Box",
      "props": {
        "data-testid": "registration-page",
        "bg": "gray.50",
        "py": [
          8,
          16
        ]
      },
      "children": [
        {
          "type": "Seo",
          "props": {
            "title": "Registration",
            "description": "Customer sign up"
          }
        },
        {
          "type": "Container",
          "props": {
            "paddingTop": 16,
            "width": [
              "100%",
              "407px"
            ],
            "bg": "white",
            "paddingBottom": 14,
            "marginTop": 8,
            "marginBottom": 8,
            "borderRadius": "base"
          },
          "children": [
            {
              "type": "RegisterForm",
              "props": {
                "submitForm": {
                  "type": "identifier",
                  "name": "submitForm"
                },
                "form": {
                  "type": "identifier",
                  "name": "form"
                },
                "clickSignIn": "<function>"
              }
            }
          ]
        }
      ]
    }
  ]
}